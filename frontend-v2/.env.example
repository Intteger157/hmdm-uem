# REST API path prefix (proxied in dev, same-origin in prod)
VITE_API_BASE=/rest

# Java backend origin for Vite dev proxy only
VITE_BACKEND_URL=http://localhost:8080

# Go server-windows origin for Vite dev proxy (/rest/windows → server-windows)
VITE_WINDOWS_BACKEND_URL=http://localhost:8082

# Windows MDM UI (uses Go /rest/windows/devices instead of Java /private/devices)
VITE_WINDOWS_MDM_ENABLED=true

# Use mock API data instead of real backend (enabled by default in dev)
# Production builds use .env.production (VITE_USE_MOCK=false)
# Set to false to hit real /rest endpoints during local development
VITE_USE_MOCK=true
