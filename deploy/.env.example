# PostgreSQL (shared by Java MDM and Go server-windows)
SQL_BASE=hmdm
SQL_USER=hmdm
SQL_PASS=hmdm

# Headwind MDM container settings (HTTP dev mode)
ADMIN_EMAIL=admin@localhost
BASE_DOMAIN=localhost
LOCAL_IP=
FORCE_RECONFIGURE=true
PROTOCOL=http
SHARED_SECRET=changeme-dev-secret
HMDM_VARIANT=os
DOWNLOAD_CREDENTIALS=
# Leave empty when deploying a custom WAR from this repository.
HMDM_URL=
CLIENT_VERSION=

# Public HTTP entrypoint (nginx gateway)
GATEWAY_PORT=8080

# Go Windows MDM service
SERVER_WINDOWS_PORT=8082
GIN_MODE=release
