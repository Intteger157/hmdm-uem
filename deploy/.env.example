# PostgreSQL (shared by Java MDM and Go server-windows)
SQL_BASE=hmdm
SQL_USER=hmdm
SQL_PASS=hmdm

# Headwind MDM container settings
#
# REQUIRED before the first `./deploy/install.sh` (or first `docker compose up`):
#   BASE_DOMAIN = public hostname phones and QR codes use (NOT localhost)
#   PROTOCOL    = https when TLS terminates on edge nginx
#   LOCAL_IP    = LAN IP of this MDM host (optional; used to fix stale APK URLs)
#
# Local dev on localhost only: ./deploy/install.sh --dev
ADMIN_EMAIL=admin@localhost
BASE_DOMAIN=
LOCAL_IP=
# Keep false when using custom ROOT.war from deploy/install.sh
FORCE_RECONFIGURE=false
PROTOCOL=http
SHARED_SECRET=changeme-dev-secret
HMDM_VARIANT=os
DOWNLOAD_CREDENTIALS=
# Required by the hmdm entrypoint script (even when ROOT.war is mounted from this repo).
HMDM_URL=https://h-mdm.com/files/hmdm-5.39.2-os.war
CLIENT_VERSION=6.36

# Public HTTP entrypoint (nginx gateway → frontend-v2 + /rest API + /rest/windows)
GATEWAY_PORT=8080

# Go Windows MDM service
SERVER_WINDOWS_PORT=8082
GIN_MODE=release
