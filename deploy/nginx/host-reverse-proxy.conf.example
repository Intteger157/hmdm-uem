# Host nginx (outside Docker) — TLS termination for Headwind MDM stack.
#
# Prerequisites:
#   - Docker gateway listening on 127.0.0.1:8080 (deploy/docker-compose.yml GATEWAY_PORT)
#   - DNS A record: test-dev-mdm.intteger.uk → your public IP
#   - Router forwards TCP 80 and 443 to this host (192.168.31.247)
#
# Install on Ubuntu/Debian:
#   sudo cp deploy/nginx/host-reverse-proxy.conf.example /etc/nginx/sites-available/test-dev-mdm.intteger.uk
#   sudo ln -sf /etc/nginx/sites-available/test-dev-mdm.intteger.uk /etc/nginx/sites-enabled/
#   sudo rm -f /etc/nginx/sites-enabled/default
#   See deploy/PRODUCTION-SETUP.md for certbot steps.

upstream hmdm_gateway {
    server 127.0.0.1:8080;
    keepalive 32;
}

# HTTP — ACME challenges + redirect to HTTPS
server {
    listen 80;
    listen [::]:80;
    server_name test-dev-mdm.intteger.uk;

    location /.well-known/acme-challenge/ {
        root /var/www/certbot;
        allow all;
    }

    location / {
        return 301 https://$host$request_uri;
    }
}

# HTTPS — proxy to Docker gateway (frontend-v2 + /rest + /rest/windows)
server {
    listen 443 ssl;
    listen [::]:443 ssl;
    http2 on;
    server_name test-dev-mdm.intteger.uk;

    ssl_certificate     /etc/letsencrypt/live/test-dev-mdm.intteger.uk/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/test-dev-mdm.intteger.uk/privkey.pem;
    include             /etc/letsencrypt/options-ssl-nginx.conf;
    ssl_dhparam         /etc/letsencrypt/ssl-dhparams.pem;

    client_max_body_size 64m;

    location / {
        proxy_pass http://hmdm_gateway;
        proxy_http_version 1.1;
        proxy_set_header Host              $host;
        proxy_set_header X-Real-IP         $remote_addr;
        proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto https;
        proxy_set_header Connection        "";
        proxy_read_timeout 300s;
        proxy_send_timeout 300s;
    }
}
