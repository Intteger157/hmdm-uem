<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">
  <Package
    Name="HMDM Windows Agent"
    Manufacturer="HMDM"
    Version="1.0.23.0"
    UpgradeCode="a1b2c3d4-e5f6-7890-abcd-ef1234567890"
    Scope="perMachine">

    <MajorUpgrade
      AllowSameVersionUpgrades="yes"
      DowngradeErrorMessage="A newer version of HMDM Agent is already installed." />
    <MediaTemplate EmbedCab="yes" />

    <InstallExecuteSequence>
      <Custom Action="EnsureAgentService" After="InstallServices" Condition="NOT REMOVE" />
      <Custom Action="NotifyServerUninstall" Before="RemoveFiles" Condition="REMOVE=&quot;ALL&quot;" />
    </InstallExecuteSequence>

    <Feature Id="MainFeature" Title="HMDM Agent" Level="1">
      <ComponentRef Id="AgentComponent" />
    </Feature>
  </Package>

  <Fragment>
    <StandardDirectory Id="ProgramFiles6432Folder">
      <Directory Id="INSTALLDIR" Name="HMDM">
        <Directory Id="AGENTDIR" Name="Agent" />
      </Directory>
    </StandardDirectory>
  </Fragment>

  <Fragment>
    <Component Id="AgentComponent" Directory="AGENTDIR" Guid="b2c3d4e5-f6a7-8901-bcde-f12345678901">
      <File Id="HMDMAgentExe" Source="$(var.AgentBinary)" KeyPath="yes" />

      <ServiceInstall
        Id="HMDMAgentServiceInstall"
        Name="HMDMAgent"
        DisplayName="HMDM Windows Agent"
        Description="Headwind MDM agent for Windows device management"
        Type="ownProcess"
        Start="auto"
        ErrorControl="normal"
        Account="LocalSystem"
        Vital="yes" />

      <ServiceControl
        Id="HMDMAgentServiceControl"
        Name="HMDMAgent"
        Start="install"
        Stop="both"
        Remove="uninstall"
        Wait="yes" />

      <RegistryKey Root="HKLM" Key="SOFTWARE\HMDM\Agent">
        <RegistryValue Name="ServerURL" Value="$(var.ServerUrl)" Type="string" />
        <RegistryValue Name="EnrollmentToken" Value="$(var.EnrollmentToken)" Type="string" />
      </RegistryKey>
    </Component>
  </Fragment>

  <Fragment>
    <CustomAction
      Id="EnsureAgentService"
      Directory="System6432Folder"
      ExeCommand="cmd.exe /c sc create HMDMAgent binPath= &quot;[AGENTDIR]HMDMAgent.exe&quot; start= auto obj= LocalSystem DisplayName= &quot;HMDM Windows Agent&quot;"
      Execute="commit"
      Impersonate="no"
      Return="ignore" />

    <CustomAction
      Id="NotifyServerUninstall"
      FileRef="HMDMAgentExe"
      ExeCommand="-uninstall"
      Execute="deferred"
      Impersonate="no"
      Return="ignore" />
  </Fragment>
</Wix>
